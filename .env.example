# === Runtime Mode ===
# Use "dev" for KAEL CLI or "prod" for SPACE BUILDER (headless)
APP_MODE=dev

# === Server Settings ===
SERVER_HOST=0.0.0.0
SERVER_PORT=10000
KAEL_URI=ws://localhost:10000

# === OpenAI API Configuration ===
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# === Tavily Search API ===
TAVILY_API_KEY=your_tavily_api_key_here

# === LangSmith Tracing ===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=python-space-agents

# === Model Behavior ===
MAX_TOKENS=4000
TEMPERATURE=0.1
LOG_LEVEL=INFO

# === Grid Layout Configuration ===
GRID_WIDTH=12
GRID_HEIGHT=8
MIN_COVERAGE_PERCENTAGE=70

# Environment configuration for Python Space Agents

# --- OpenAI API Configuration ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# --- Tavily Search API (for research agent) ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- LangSmith Configuration (optional - for tracing and monitoring) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=python-space-agents

# --- Application Configuration ---
LOG_LEVEL=INFO
MAX_TOKENS=4000
TEMPERATURE=0.1

# --- Grid Configuration ---
GRID_WIDTH=12
GRID_HEIGHT=8
MIN_COVERAGE_PERCENTAGE=70

# --- Server Configuration ---
SERVER_HOST=0.0.0.0
SERVER_PORT=10000

# --- Client Configuration ---
CLIENT_URI=ws://localhost:10000
